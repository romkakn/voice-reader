{
  "manifest_version": 3,
  "name": "Voice Reader",
  "version": "0.1.0",
  "description": "Select text and listen to it read aloud with adjustable voice, speed, and tone.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/lib/chunker.js",
        "src/tts/engine.js",
        "src/tts/webspeech.js",
        "src/tts/piper.js",
        "src/ui/bar.js",
        "src/ui/captions.js",
        "src/content.js"
      ],
      "css": [
        "src/ui/bar.css",
        "src/ui/captions.css"
      ]
    }
  ],
  "options_page": "src/options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://huggingface.co https://*.huggingface.co https://*.hf.co;"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html", "src/offscreen/offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
